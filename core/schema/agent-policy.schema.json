{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rore/agent-redline/core/schema/agent-policy.schema.json",
  "title": "agent-redline policy schema v1",
  "description": "Schema for agent-policy.yaml. See docs/POLICY_SCHEMA.md for the normative reference.",
  "type": "object",
  "required": ["version", "project", "zones"],
  "additionalProperties": false,

  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Currently must be 1."
    },

    "project": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "extension": {
          "type": "string",
          "description": "Names the language extension, e.g. spring-archunit."
        }
      }
    },

    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unclassifiedZone": { "enum": ["gray", "red", "blue"] },
        "grayMode": { "enum": ["cautious", "warn", "allow"] }
      }
    },

    "zones": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "red":       { "$ref": "#/$defs/zoneList" },
        "blue":      { "$ref": "#/$defs/zoneList" },
        "grayWatch": { "$ref": "#/$defs/zoneList" }
      },
      "anyOf": [
        { "required": ["red"] },
        { "required": ["blue"] }
      ],
      "description": "At least one of red or blue must be present and non-empty."
    },

    "boundaryBackend": {
      "type": "string",
      "description": "Name of the enforcement tool: archunit, dependency-cruiser, import-linter, semgrep, etc."
    },

    "boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "from", "forbidImports"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "kebab-case-string; unique within file."
          },
          "description": { "type": "string", "minLength": 1 },
          "from":         { "type": "string", "minLength": 1 },
          "forbidImports": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "severity": { "enum": ["error", "warn"] }
        }
      }
    },

    "api": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["openapi-from-controllers", "openapi-spec-file", "graphql", "proto", "none"]
        },
        "generationCommand": { "type": "string" },
        "specPath": { "type": "string" },
        "diffMode": { "enum": ["structural", "full"] },
        "checkpoint": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "openapi-from-controllers" } }, "required": ["type"] },
          "then": { "required": ["generationCommand"] }
        }
      ]
    },

    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "migrationPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "checkpoint": { "type": "string" },
        "notes":      { "type": "string" }
      },
      "required": ["migrationPaths"]
    },

    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "checkpoint": { "type": "string" }
      },
      "required": ["paths"]
    },

    "runtimeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "checkpoint": { "type": "string" }
      },
      "required": ["paths"]
    },

    "prRules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxChangedFiles":  { "$ref": "#/$defs/warnFail" },
        "maxLinesChanged":  { "$ref": "#/$defs/warnFail" },
        "rejectVerboseGeneratedDescriptions": { "type": "boolean" },
        "requireVerificationSection": { "type": "boolean" }
      }
    },

    "changeRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["when", "action"],
        "additionalProperties": false,
        "properties": {
          "when": {
            "enum": [
              "blue_only", "red_changed", "gray_changed", "boundary_violation",
              "api_changed", "schema_changed", "security_changed",
              "pr_size_warn", "pr_size_fail"
            ]
          },
          "action": {
            "enum": ["allow", "warn", "require_checkpoint", "require_split", "fail"]
          },
          "checkpoint": { "type": "string" },
          "value": { "type": "integer" }
        }
      }
    },

    "checkpoints": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z0-9]+(-[a-z0-9]+)*$": {
          "type": "object",
          "required": ["satisfiedBy"],
          "additionalProperties": false,
          "properties": {
            "description": { "type": "string" },
            "satisfiedBy": {
              "type": "array",
              "minItems": 1,
              "items": {
                "oneOf": [
                  { "const": "codeownerApproval" },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": { "label": { "type": "string", "minLength": 1 } },
                    "required": ["label"]
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": { "reviewerCount": { "type": "integer", "minimum": 1 } },
                    "required": ["reviewerCount"]
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": { "team": { "type": "string", "minLength": 1 } },
                    "required": ["team"]
                  }
                ]
              }
            }
          }
        }
      },
      "additionalProperties": false
    },

    "modes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": { "enum": ["shadow", "binding"] },
        "perCheck": {
          "type": "object",
          "additionalProperties": { "enum": ["shadow", "binding"] }
        }
      }
    },

    "excludes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },

  "$defs": {
    "zoneList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "additionalProperties": false,
        "properties": {
          "path":       { "type": "string", "minLength": 1 },
          "reason":     { "type": "string", "minLength": 1 },
          "checkpoint": { "type": "string" }
        }
      }
    },
    "warnFail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "warn": { "type": "integer", "minimum": 1 },
        "fail": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
