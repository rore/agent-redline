# agent-policy.yaml — generated by agent-redline bootstrap
#
# This is a starting template. Bootstrap fills it in based on inspection
# of the consuming repo. The shape is normative (see docs/POLICY_SCHEMA.md);
# the values are repo-specific.
#
# After bootstrap, treat this file as red-zone: changes to it should go
# through architecture-review.

version: 1

project:
  name: <repo-name>
  extension: <extension-name>           # e.g. spring-archunit; or omit for zone-only

defaults:
  unclassifiedZone: gray
  grayMode: cautious

zones:
  red:
    # Architecture-test definition files MUST be red. Without this entry,
    # an agent could weaken the boundary backend silently.
    - path: <arch-test-glob>
      reason: dependency-rule definitions; weakening these requires explicit checkpoint
      checkpoint: architecture-review
    # Add the actual zones from the language extension's profile.md, with
    # paths substituted for the repo's real package names.
    # - path: src/main/java/**/domain/**
    #   reason: domain model and invariants
    #   checkpoint: architecture-review

  blue:
    - path: src/test/**
      reason: tests (excluding architecture/**)
    - path: docs/**
      reason: documentation

  grayWatch:
    # Paths that look like one zone but might behave like another;
    # surfaced in PR comments even when they overlap with blue/red.
    # Populated from the extension's profile.md.

# boundaryBackend names the enforcement tool. Omit for zone-only governance.
# boundaryBackend: archunit

# boundaries describe forbidden dependencies. The boundary-rule backend
# enforces them; the reporter surfaces the configured rules and reads
# backend output.
# boundaries:
#   - id: domain-must-not-import-adapters
#     description: Domain layer must not depend on adapter implementations
#     from: src/main/java/**/domain/**
#     forbidImports:
#       - src/main/java/**/adapter/**
#     severity: error

# api: { type: none }
# persistence: { migrationPaths: [...] }
# security: { paths: [...] }
# runtimeConfig: { paths: [...] }

prRules:
  maxChangedFiles:
    warn: 50
    fail: 100
  maxLinesChanged:
    warn: 1000
    fail: 2000
  rejectVerboseGeneratedDescriptions: true
  requireVerificationSection: true

checkpoints:
  architecture-review:
    description: Architecture review for structural changes
    satisfiedBy:
      - codeownerApproval
      - label: architecture-reviewed
  # Add others as needed:
  # api-review, persistence-review, security-review, ops-review

modes:
  default: shadow
  perCheck:
    boundary_violation: binding

